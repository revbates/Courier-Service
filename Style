body {
  font-family: sans-serif;
  padding: 20px;
  background: #f4f4f4;
}
h1 {
  text-align: center;
}
input, textarea, select, button {
  width: 100%;
  padding: 10px;
  margin: 8px 0;
  box-sizing: border-box;
}
button {
  background: #007bff;
  color: white;
  border: none;
  cursor: pointer;
  font-size: 16px;
}
button:hover {
  background: #0056b3;
}
